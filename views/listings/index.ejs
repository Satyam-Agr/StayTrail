<% layout('layoutes/boilerplate') -%>
<section class="mb-4">
  <h1 class="page-title mb-1">Stays for Every Kind of Trip</h1>
  <p class="page-subtitle mb-0">Find unique places to stay around the world.</p>
</section>

<section class="listings-grid">
  <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-3">
    <% for (let listing of listings) { %>
      <div class="col">
        <article class="card listing-card h-100">
          <a href="/listings/<%= listing._id %>" class="listing-image-wrap">
            <img src="<%= listing.image %>" class="listing-image" alt="<%= listing.title %>">
          </a>
          <div class="card-body d-flex flex-column">
            <h2 class="listing-title">
              <a href="/listings/<%= listing._id %>"><%= listing.title %></a>
            </h2>
            <p class="listing-location mb-2"><%= listing.location %>, <%= listing.country %></p>
            <p class="listing-price mt-auto mb-0">
              <span>&#8377;<%= listing.price.toLocaleString("en-in") %></span> night
            </p>
          </div>
        </article>
      </div>
    <% } %>
  </div>
</section>
