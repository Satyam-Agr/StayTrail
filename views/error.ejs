<% layout('layoutes/boilerplate') -%>
<section class="row justify-content-center">
  <div class="col-12 col-lg-8 col-xl-7">
    <article class="card border-danger-subtle shadow-sm">
      <div class="card-body p-4 p-lg-5">
        <h1 class="h3 text-danger mb-3">Something went wrong</h1>
        <p class="mb-2"><strong>Status:</strong> <%= statusCode %></p>
        <p class="mb-4"><strong>Message:</strong> <%= message %></p>
        <a href="/listings" class="btn btn-outline-dark">Back to Listings</a>
      </div>
    </article>
  </div>
</section>
